# ---- Supabase (required) ----
# Found in Supabase dashboard: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# The "secret" key (privileged). Used ONLY by the weekly-email server job. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# ---- Weekly restock email (required for the nudge) ----
# Free account at https://resend.com -> API Keys
RESEND_API_KEY=your-resend-api-key
# Where the weekly restock email is sent (your email)
RESTOCK_EMAIL_TO=you@example.com
# From address. Use onboarding@resend.dev until you verify your own domain.
RESTOCK_EMAIL_FROM=Tantaan Tiki Bar <onboarding@resend.dev>

# ---- Cron protection (required) ----
# Any long random string. Vercel sends this so only Vercel can trigger the email.
CRON_SECRET=make-this-a-long-random-string

# ---- Claude (required for photo scan + sommelier recommendations) ----
# From https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-...
